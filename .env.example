# EC2 호스트의 ~/app/.env 로 복사해 실제 값으로 채운다. (절대 커밋하지 말 것)
# 환경변수명은 application.yml(prod)의 ${...} 플레이스홀더와 일치해야 한다.

SPRING_PROFILES_ACTIVE=prod

# --- ECR (docker-compose image 참조) ---
ECR_REGISTRY=<account-id>.dkr.ecr.ap-northeast-2.amazonaws.com
ECR_REPOSITORY=jjimkong-backend

# --- MySQL (AWS RDS) ---
SPRING_DATASOURCE_URL=jdbc:mysql://<rds-endpoint>.ap-northeast-2.rds.amazonaws.com:3306/jjimkong?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- Redis (compose의 redis 서비스 사용 시 host=redis) ---
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=

# --- OAuth2 (실제 키 이름은 application.yml 매핑에 맞춰 조정) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 네이버 검색 API (장소 검색 기능) ---
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
